// [WZ_PROOF: L2] Index 0 handled OUTSIDE the loop

void FillBuffers(int limit)
{
ArraySetAsSeries(BufRSI, true);
ArraySetAsSeries(BufUpper, true);
ArraySetAsSeries(BufLower, true);

for(int i = limit; i >= 1; i--)
{
double r = GetRSIVal(i);
BufRSI[i] = r; BufUpper[i] = EMPTY_VALUE; BufLower[i] = EMPTY_VALUE;
}

double r0 = GetRSIVal(0);
BufRSI[0] = r0; BufUpper[0] = EMPTY_VALUE; BufLower[0] = EMPTY_VALUE;
}

//+==================================================================+
//| SECTION 15: FORWARD LOOP — DASHBOARD DRAWING |
//+==================================================================+
// [WZ_PROOF: L5] No ObjectDelete
// [WZ_PROOF: M4] All positions from InpFontSize

void DrawDashboard()
{
if(!InpShowDash) return;

DrawRect("BG", InpDashX, InpDashY, g_dashWidth, g_dashTotalHeight, g_bgPrimary, g_borderColor, 0);
DrawRect("HD", InpDashX, InpDashY, g_dashWidth, g_headerHeight, g_bgHeader, g_borderColor, 1);
DrawTxt("TITLE", " RSI DASHBOARD",
InpDashX+(int)(InpFontSize*0.5), InpDashY+(int)(InpFontSize*0.4),
g_textPrimary, InpFontSize+1);

double curRSI = GetRSIVal(1);
ENUM_RSI_STATE st = CheckRSI(curRSI);

SDashRow rows[6];
rows[0].label="Symbol"; rows[0].value=Symbol();
rows[0].rowColor=g_bgSecondary; rows[0].isHighlight=false;
rows[1].label="Period"; rows[1].value=TimeFrameToString(Period());
rows[1].rowColor=g_bgPrimary; rows[1].isHighlight=false;
rows[2].label="RSI Value"; rows[2].value=DoubleToString(curRSI,2);
rows[2].rowColor=g_bgSecondary; rows[2].isHighlight=(st!=RSI_NEUTRAL);
rows[3].label="Status"; rows[3].value=RSIStateToString(st);
rows[3].rowColor=g_bgPrimary; rows[3].isHighlight=(st!=RSI_NEUTRAL);
rows[4].label="Upper Level"; rows[4].value=DoubleToString(InpUpperLevel,1);
rows[4].rowColor=g_bgSecondary; rows[4].isHighlight=false;
rows[5].label="Lower Level"; rows[5].value=DoubleToString(InpLowerLevel,1);
rows[5].rowColor=g_bgPrimary; rows[5].isHighlight=false;

for(int i = 0; i < 6; i++)
{
string pfx = "R" + IntegerToString(i);
int yp = g_dataRowStart + (i * g_rowH);
color bgC = rows[i].rowColor;
if(rows[i].isHighlight) bgC = C'60,30,30';

DrawRect(pfx+"_bg", InpDashX+2, yp, g_dashWidth-4, g_rowH-2, bgC, clrNONE, 2);
DrawTxt(pfx+"_l", " "+rows[i].label,
InpDashX+(int)(InpFontSize*0.6), yp+(int)(InpFontSize*0.4),
g_textSecondary, InpFontSize-1);

color valCol = g_textPrimary;
if(rows[i].label=="Status" && st==RSI_OVERBOUGHT) valCol=InpBullColor;
if(rows[i].label=="Status" && st==RSI_OVERSOLD) valCol=InpBearColor;
if(rows[i].isHighlight && rows[i].label=="RSI Value") valCol=InpAlertColor;

int vx = InpDashX + g_dashWidth - (int)(InpFontSize * 8);
DrawTxt(pfx+"_v", rows[i].value, vx, yp+(int)(InpFontSize*0.4), valCol, InpFontSize, "Arial Bold");
}

