//+==================================================================+
//| SECTION 7: GOLDEN LIMIT CALCULATOR |
//+==================================================================+
// [WZ_PROOF: L1] CalcSafeLimit — prevents terminal freeze

int CalculateSafeLimit(int rates_total, int prev_calculated)
{
int limit;
if(prev_calculated == 0)
{
limit = MathMin(rates_total - 1, InpMaxBars);
LogChain("First run. Capping to " + IntegerToString(limit) + " bars.",
LOG_INFO, "CalcLimit");
}
else
{
if(InpRecalcLastBar)
limit = rates_total - prev_calculated + 1;
else
limit = rates_total - prev_calculated;
if(limit <= 0)
return(0);
}
return(limit);
}

