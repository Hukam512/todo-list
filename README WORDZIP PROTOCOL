InpDashX+(int)(InpFontSize*0.6),
yPos+(int)(InpFontSize*0.4),
g_textSecondary, InpFontSize-1);

color valCol = g_textPrimary;
if(rows[i].label=="Signal" && sig==SIGNAL_BUY) valCol=InpBullColor;
if(rows[i].label=="Signal" && sig==SIGNAL_SELL) valCol=InpBearColor;
if(rows[i].isHighlighted) valCol=clrOrange;

int vx = InpDashX + g_dashWidth - (int)(InpFontSize * 8);
DrawText(pfx+"_v", rows[i].value,
vx, yPos+(int)(InpFontSize*0.4),
valCol, InpFontSize, "Arial Bold");
}

// [WZ_PROOF: V9] Single ChartRedraw at end
ChartRedraw(0);
}

