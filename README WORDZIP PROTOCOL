void LogChain(string message, ENUM_LOG_LEVEL level = LOG_INFO, string funcName = "")
{
string levelStr;
switch(level)
{
case LOG_INFO: levelStr = "INFO"; break;
case LOG_WARN: levelStr = "WARN"; break;
