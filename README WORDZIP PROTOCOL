ObjectSetInteger(0,f,OBJPROP_HIDDEN,true); }
ObjectSetInteger(0,f,OBJPROP_XDISTANCE,x);
ObjectSetInteger(0,f,OBJPROP_YDISTANCE,y);
ObjectSetInteger(0,f,OBJPROP_XSIZE,w);
ObjectSetInteger(0,f,OBJPROP_YSIZE,h);
