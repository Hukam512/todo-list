ObjectSetInteger(0,f,OBJPROP_CORNER,CORNER_LEFT_UPPER);
ObjectSetInteger(0,f,OBJPROP_BACK,false);
ObjectSetInteger(0,f,OBJPROP_ZORDER,z);
}

void DrawTxt(string nm, string tx, int x, int y, color cl, int fs=-1, string ft="Arial Bold")
{
