void LogChain(string msg, ENUM_LOG_LEVEL lvl = LOG_INFO, string fn = "")
{
string l = (lvl==LOG_INFO)?"INFO":(lvl==LOG_WARN)?"WARN":"ERROR";
PrintFormat("[%s] [%s] [%s%s] %s",
TimeToString(TimeCurrent(),TIME_DATE|TIME_SECONDS), l, g_objPrefix, fn, msg);
}

//+==================================================================+
//| SECTION 7: GOLDEN LIMIT CALCULATOR |
//+==================================================================+
// [WZ_PROOF: L1] Prevents terminal freeze

int CalculateSafeLimit(int rt, int pc)
{
if(pc == 0) { int lim = MathMin(rt-1, InpMaxBars);
LogChain("Cap="+IntegerToString(lim), LOG_INFO, "CalcLimit"); return(lim); }
int lim = InpRecalcLastBar ? (rt-pc+1) : (rt-pc);
return(lim <= 0 ? 0 : lim);
}

