double GetRSIVal(int shift) { return(iRSI(NULL, 0, InpRSIPeriod, PRICE_CLOSE, shift)); }
ENUM_RSI_STATE CheckRSI(double val)
{
if(val >= InpUpperLevel) return(RSI_OVERBOUGHT);
if(val <= InpLowerLevel) return(RSI_OVERSOLD);
return(RSI_NEUTRAL);
}

