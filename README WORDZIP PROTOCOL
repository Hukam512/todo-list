rows[6].rowColor=g_bgSecondary; rows[6].isHighlighted=false;
rows[7].label="Bars Since";
int bs = BarsSinceLastSignal(sig);
rows[7].value=(bs>=0)?IntegerToString(bs):"N/A";
rows[7].rowColor=g_bgPrimary; rows[7].isHighlighted=false;

//=== FORWARD LOOP: rows 0 -> 7 ===
for(int i = 0; i < 8; i++)
{
