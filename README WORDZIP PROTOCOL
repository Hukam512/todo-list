ENUM_SIGNAL sig = CalculateSignal(1);
rows[5].label="Signal";
rows[5].value=(sig==SIGNAL_BUY)?"BUY":(sig==SIGNAL_SELL)?"SELL":"NONE";
rows[5].rowColor=g_bgPrimary;
rows[5].isHighlighted=(sig!=SIGNAL_NONE);
rows[6].label="Strength";
