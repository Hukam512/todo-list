int OnCalculate(const int rates_total,
const int prev_calculated,
const datetime &time[],
const double &open[],
const double &high[],
const double &low[],
const double &close[],
const long &tick_volume[],
const long &volume[],
const int &spread[])
{
if(rates_total < InpRSIPeriod + 1) return(0);

//=== STEP 1: GOLDEN LIMIT (always first) ===
int limit = CalculateSafeLimit(rates_total, prev_calculated);

//=== STEP 2: FILL BUFFERS (reverse loop) ===
if(limit > 0) FillBuffers(limit);

//=== STEP 3: DRAW DASHBOARD (forward loop) ===
DrawDashboard();

//=== STEP 4: ALERT CHECK (only on new bar) ===
if(rates_total != prev_calculated)
{
ENUM_RSI_STATE st = CheckRSI(GetRSIVal(1));
if(st != RSI_NEUTRAL && st != g_lastRSIState)
TriggerAlert(st, Bars);
g_lastRSIState = st;
}

//=== STEP 5: First run complete ===
if(g_isFirstRun) { g_isFirstRun = false;
LogChain("First tick processed.", LOG_INFO, "OnCalc"); }

return(rates_total);
}
