//+==================================================================+
//| SECTION 19: ONCALCULATE — THE MASTER ENGINE |
//+==================================================================+
// [WZ_PROOF: L1] CalcSafeLimit FIRST
// [WZ_PROOF: B5] Never loop rates_total directly

int OnCalculate(const int rates_total,
const int prev_calculated,
const datetime &time[],
const double &open[],
const double &high[],
const double &low[],
const double &close[],
const long &tick_volume[],
const long &volume[],
const int &spread[])
{
if(rates_total < InpSlowPeriod + 1) return(0);

//=== STEP 1: GOLDEN LIMIT (always first) ===
int limit = CalculateSafeLimit(rates_total, prev_calculated);

//=== STEP 2: FILL BUFFERS (reverse loop) ===
if(limit > 0) FillChartBuffers(limit);

//=== STEP 3: DRAW DASHBOARD (forward loop) ===
DrawDashboard();

//=== STEP 4: ALERT CHECK ===
if(rates_total != prev_calculated)
{
ENUM_SIGNAL newSignal = CalculateSignal(1);
if(newSignal != SIGNAL_NONE && newSignal != g_prevSignal)
{ TriggerAlert(newSignal, 1); g_prevSignal = newSignal; }
}

//=== STEP 5: First run complete ===
if(g_isFirstRun) { g_isFirstRun = false;
LogChain("First tick processed.", LOG_INFO, "OnCalc"); }

return(rates_total);
}
