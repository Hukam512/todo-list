string FormatPrice(double p) { return(DoubleToString(p,(int)MarketInfo(Symbol(),MODE_DIGITS))); }
string RSIStateToString(ENUM_RSI_STATE s)
{ return(s==RSI_OVERBOUGHT?"OVERBOUGHT":(s==RSI_OVERSOLD?"OVERSOLD":"NEUTRAL")); }
string TimeFrameToString(int tf)
{
switch(tf) {
case PERIOD_M1:return("M1"); case PERIOD_M5:return("M5");
case PERIOD_M15:return("M15"); case PERIOD_M30:return("M30");
case PERIOD_H1:return("H1"); case PERIOD_H4:return("H4");
case PERIOD_D1:return("D1"); case PERIOD_W1:return("W1");
case PERIOD_MN1:return("MN"); default:return("TF"+IntegerToString(tf)); }
}

