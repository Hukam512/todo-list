string msg = "";
if(st == RSI_OVERBOUGHT)
msg = Symbol()+" OVERBOUGHT! RSI > "+DoubleToString(InpUpperLevel,1);
else if(st == RSI_OVERSOLD)
msg = Symbol()+" OVERSOLD! RSI < "+DoubleToString(InpLowerLevel,1);
else return;
LogChain(msg, LOG_WARN, "Alert");
Alert(msg);
}

