int CalcSafeLimit()
{
   int minBars = RSI_Period * 2 + 10;
   int counted = IndicatorCounted();
   if(counted > 0) counted--;
   int limit = Bars - counted - 1;
   if(Bars < minBars) return 0;
   if(limit > Bars - minBars) limit = Bars - minBars;
   if(limit < 0) limit = 0;
