// ── INLINE MATH (Module 14 Block A) ──
double WZ_EMA(double prev, double price, int period)
{
   if(period < 2) return price;
   double k = 2.0 / (period + 1.0);
   return price * k + prev * (1.0 - k);
}

double WZ_SafeDiv(double num, double denom, double fallback)
{
   if(MathAbs(denom) < 1e-10) return fallback;
   return num / denom;
}

double WZ_Clamp(double v, double lo, double hi)
{
   if(v < lo) return lo;
   if(v > hi) return hi;
   return v;
}

// ── CHART-PERCENTAGE UI (Module 14 Block C) ──
int WZ_PctX(double pct)
{  return (int)(ChartGetInteger(0, CHART_WIDTH_IN_PIXELS) * WZ_Clamp(pct,0,100) / 100.0); }

int WZ_PctY(double pct)
{  return (int)(ChartGetInteger(0, CHART_HEIGHT_IN_PIXELS) * WZ_Clamp(pct,0,100) / 100.0); }

bool WZ_CreateLabel(string name, double xPct, double yPct, string text, color clr, int size)
{
   // WZ_PROOF: ObjectFind guard before ObjectCreate
   if(ObjectFind(name) >= 0)
   {  ObjectSetText(name, text, size, "Courier New", clr); return true; }
   if(!ObjectCreate(name, OBJ_LABEL, 0, 0, 0))
   {  Print("ObjectCreate failed: ", name, " err=", GetLastError()); return false; }
   ObjectSet(name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
   ObjectSet(name, OBJPROP_XDISTANCE, WZ_PctX(xPct));
   ObjectSet(name, OBJPROP_YDISTANCE, WZ_PctY(yPct));
   ObjectSetText(name, text, size, "Courier New", clr);
   ObjectSet(name, OBJPROP_SELECTABLE, false);
   return true;
}

// ── DASHBOARD (Module 14 Block C) ──
