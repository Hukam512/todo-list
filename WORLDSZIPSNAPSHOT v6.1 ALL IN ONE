// ── INLINE MATH (Module 14 Block A) ──
double WZ_EMA(double prev, double price, int period)
{
   if(period < 2) return price;
   double k = 2.0 / (period + 1.0);
   return price * k + prev * (1.0 - k);
}

double WZ_TrueRange(int bar)
{
   // WZ_PROOF: Bounds check for bar+1 access
   if(bar >= Bars - 1) return High[bar] - Low[bar];
   double tr = High[bar] - Low[bar];
   tr = MathMax(tr, MathAbs(High[bar] - Close[bar+1]));
   tr = MathMax(tr, MathAbs(Low[bar] - Close[bar+1]));
   return tr;
}

double WZ_ATR_Step(double prev, int bar, int period)
{
   if(period <= 0) return 0;
   double tr = WZ_TrueRange(bar);
   if(prev <= 0) return tr;
   return (prev * (period-1) + tr) / period;
}

double WZ_SafeDiv(double num, double denom, double fallback)
{
   if(MathAbs(denom) < 1e-10) return fallback;
   return num / denom;
}

double WZ_Clamp(double v, double lo, double hi)
