   SetIndexStyle(0, DRAW_LINE, STYLE_SOLID, 2, clrDodgerBlue);
   SetIndexStyle(1, DRAW_LINE, STYLE_SOLID, 2, clrOrangeRed);
   SetIndexStyle(2, DRAW_LINE, STYLE_DOT,   1, clrGold);
   SetIndexLabel(0, "FastEMA("+IntegerToString(FastPeriod)+")");
   SetIndexLabel(1, "SlowEMA("+IntegerToString(SlowPeriod)+")");
   SetIndexLabel(2, "Signal("+IntegerToString(SignalPeriod)+")");
   IndicatorShortName(WZ_NAME+"("+IntegerToString(FastPeriod)+","+
                      IntegerToString(SlowPeriod)+","+IntegerToString(SignalPeriod)+")");
   g_CalcCount=0; g_LastFlight=0;
   if(FastPeriod<2 || SlowPeriod<2 || SignalPeriod<2 || FastPeriod>=SlowPeriod || ATR_Period<2)
   {  Print("ERROR: Invalid parameters."); return INIT_PARAMETERS_INCORRECT; }
   WZ_PrintPresets();
   Print(WZ_NAME," initialized. Integrity: ",WZ_INTEGRITY);
   return INIT_SUCCEEDED;
}

// WZ_PROOF: CalcSafeLimit first. Reverse loop. Buffer[0] outside loop.
// WZ_PROOF: Pure inline math. No handles. No CopyBuffer.
int start()
{
   int limit = CalcSafeLimit();
   if(limit <= 0) return 0;
   g_CalcCount++;

   double emaF = Close[limit];
   double emaS = Close[limit];
   double sig  = 0;
   double atr  = 0;

   for(int i = limit; i >= 1; i--)
   {
      emaF = WZ_EMA(emaF, Close[i], FastPeriod);
      emaS = WZ_EMA(emaS, Close[i], SlowPeriod);
      double macd = emaF - emaS;
      sig = WZ_EMA(sig, macd, SignalPeriod);
      atr = WZ_ATR_Step(atr, i, ATR_Period);
      FastEMA_Buf[i] = emaF;
      SlowEMA_Buf[i] = emaS;
      Signal_Buf[i]  = sig;
   }

   emaF = WZ_EMA(emaF, Close[0], FastPeriod);
   emaS = WZ_EMA(emaS, Close[0], SlowPeriod);
   double macd0 = emaF - emaS;
   sig = WZ_EMA(sig, macd0, SignalPeriod);
   atr = WZ_ATR_Step(atr, 0, ATR_Period);
   FastEMA_Buf[0] = emaF;
   SlowEMA_Buf[0] = emaS;
   Signal_Buf[0]  = sig;

   g_LastFast=emaF; g_LastSlow=emaS; g_LastSignal=sig; g_LastATR=atr;

   WZ_DrawDashboard();
   WZ_FlightRecorder(emaF, emaS, sig, atr, limit);
   return 0;
}

