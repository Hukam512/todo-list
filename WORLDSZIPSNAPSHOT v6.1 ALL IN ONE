int OnInit()
{
   SetIndexBuffer(0, RSI_Buf);
   ArraySetAsSeries(RSI_Buf, true);
   SetIndexStyle(0, DRAW_LINE, STYLE_SOLID, 2, clrMediumPurple);
   SetIndexLabel(0, "RSI("+IntegerToString(RSI_Period)+")");
   IndicatorShortName(WZ_NAME+"("+IntegerToString(RSI_Period)+")");
   g_CalcCount=0; g_LastFlight=0; g_LastRSI=50.0;
   if(RSI_Period<2)
   {  Print("ERROR: RSI_Period must be >= 2."); return INIT_PARAMETERS_INCORRECT; }
   Print(WZ_NAME," initialized. Integrity: ",WZ_INTEGRITY);
   return INIT_SUCCEEDED;
}

// WZ_PROOF: CalcSafeLimit first. Reverse loop. Buffer[0] outside loop.
// WZ_PROOF: Wilder smoothing RSI. No handles. No CopyBuffer.
int start()
{
   int limit = CalcSafeLimit();
   if(limit <= 0) return 0;
   g_CalcCount++;

   // Seed: SMA of gains/losses over RSI_Period bars ending at bar limit
   double sumGain=0, sumLoss=0;
   for(int s=0; s<RSI_Period; s++)
   {
      int bar = limit + RSI_Period - s;
      double delta = Close[bar] - Close[bar+1];
      if(delta > 0) sumGain += delta;
      else sumLoss += MathAbs(delta);
   }
   double avgGain = sumGain / RSI_Period;
   double avgLoss = sumLoss / RSI_Period;

   // Main reverse loop — Wilder smoothing
   for(int i = limit; i >= 1; i--)
   {
      double delta = Close[i] - Close[i+1];
      double gain = (delta > 0) ? delta : 0;
      double loss = (delta < 0) ? -delta : 0;
      avgGain = (avgGain * (RSI_Period-1) + gain) / RSI_Period;
      avgLoss = (avgLoss * (RSI_Period-1) + loss) / RSI_Period;
      RSI_Buf[i] = WZ_SafeDiv(avgGain * 100.0, avgGain + avgLoss, 50.0);
   }

   // Buffer[0] outside loop
   double delta0 = Close[0] - Close[1];
   double gain0 = (delta0 > 0) ? delta0 : 0;
   double loss0 = (delta0 < 0) ? -delta0 : 0;
   avgGain = (avgGain * (RSI_Period-1) + gain0) / RSI_Period;
   avgLoss = (avgLoss * (RSI_Period-1) + loss0) / RSI_Period;
   RSI_Buf[0] = WZ_SafeDiv(avgGain * 100.0, avgGain + avgLoss, 50.0);

   g_LastRSI = RSI_Buf[0];
   g_LastAvgGain = avgGain;
   g_LastAvgLoss = avgLoss;

   WZ_DrawDashboard();
   WZ_FlightRecorder(RSI_Buf[0], limit);
   return 0;
}

void OnDeinit(const int reason)
{
   Comment("");
   ObjectsDeleteAll(0, DASH_PREFIX);
   ChartRedraw();
   Print(WZ_NAME," deinitialized. Reason=",reason);
}
