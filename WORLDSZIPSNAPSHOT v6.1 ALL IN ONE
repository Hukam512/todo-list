      (g_LastFast>g_LastSlow)?clrLime:clrTomato, DashFontSize);
   ChartRedraw();
}

// ── FLIGHT RECORDER (Module 14 Block D) ──
void WZ_FlightRecorder(double fast, double slow, int limit)
{
   if(!ShowFlight) return;
   uint now = GetTickCount();
   if(now-g_LastFlight<500 && g_LastFlight!=0) return;
   g_LastFlight=now;
   string s = "\n=== FLIGHT RECORDER ===\n";
   s += WZ_NAME+" v"+WZ_VERSION+"  |  "+Symbol()+" "+IntegerToString(Period())+"m\n";
   s += "Fast: "+DoubleToStr(fast,_Digits)+"\n";
   s += "Slow: "+DoubleToStr(slow,_Digits)+"\n";
   s += "Bias: "+(fast>slow?"BULLISH":"BEARISH")+"\n";
   s += "Spread: "+DoubleToStr(MarketInfo(Symbol(),MODE_SPREAD)*Point,_Digits)+"\n";
   s += "Limit: "+IntegerToString(limit)+"  Calcs: "+IntegerToString(g_CalcCount);
   Comment(s);
}

// ── LIMIT CALCULATION ──
int CalcSafeLimit()
{
   int minBars = SlowPeriod + 10;
   int counted = IndicatorCounted();
   if(counted > 0) counted--;
   int limit = Bars - counted - 1;
   if(Bars < minBars) return 0;
   if(limit > Bars - minBars) limit = Bars - minBars;
   if(limit < 0) limit = 0;
   return limit;
}

int OnInit()
{
   SetIndexBuffer(0, FastEMA_Buf);  ArraySetAsSeries(FastEMA_Buf, true);
   SetIndexBuffer(1, SlowEMA_Buf);  ArraySetAsSeries(SlowEMA_Buf, true);
   SetIndexStyle(0, DRAW_LINE, STYLE_SOLID, 2, clrDodgerBlue);
   SetIndexStyle(1, DRAW_LINE, STYLE_SOLID, 2, clrOrangeRed);
   SetIndexLabel(0, "FastEMA("+IntegerToString(FastPeriod)+")");
   SetIndexLabel(1, "SlowEMA("+IntegerToString(SlowPeriod)+")");
   IndicatorShortName(WZ_NAME+"("+IntegerToString(FastPeriod)+","+IntegerToString(SlowPeriod)+")");
   g_CalcCount=0; g_LastFlight=0;
   if(FastPeriod<2 || SlowPeriod<2 || FastPeriod>=SlowPeriod)
   {  Print("ERROR: Invalid periods."); return INIT_PARAMETERS_INCORRECT; }
   Print(WZ_NAME," initialized. Integrity: ",WZ_INTEGRITY);
   return INIT_SUCCEEDED;
}

// WZ_PROOF: CalcSafeLimit first. Reverse loop. Buffer[0] outside loop.
int start()
{
   int limit = CalcSafeLimit();
   if(limit <= 0) return 0;
   g_CalcCount++;

   double emaF = Close[limit];
   double emaS = Close[limit];

   for(int i = limit; i >= 1; i--)
   {
      emaF = WZ_EMA(emaF, Close[i], FastPeriod);
      emaS = WZ_EMA(emaS, Close[i], SlowPeriod);
      FastEMA_Buf[i] = emaF;
      SlowEMA_Buf[i] = emaS;
   }

   emaF = WZ_EMA(emaF, Close[0], FastPeriod);
   emaS = WZ_EMA(emaS, Close[0], SlowPeriod);
   FastEMA_Buf[0] = emaF;
   SlowEMA_Buf[0] = emaS;
   g_LastFast=emaF; g_LastSlow=emaS;

   WZ_DrawDashboard();
   WZ_FlightRecorder(emaF, emaS, limit);
   return 0;
}

void OnDeinit(const int reason)
{
   Comment("");
   ObjectsDeleteAll(0, DASH_PREFIX);
   ChartRedraw();
   Print(WZ_NAME," deinitialized. Reason=",reason);
}
